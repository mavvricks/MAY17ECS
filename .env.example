APP_NAME=Eloquente
APP_ENV=production
APP_KEY=
APP_DEBUG=false
APP_URL=https://your-domain.example

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file
# APP_MAINTENANCE_STORE=database

# PHP_CLI_SERVER_WORKERS=4

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=warning

DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=eloquente
DB_USERNAME=eloquente_user
DB_PASSWORD=change_me

SESSION_DRIVER=redis
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=local
QUEUE_CONNECTION=redis

CACHE_STORE=redis
# CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=smtp
MAIL_HOST=mailpit
MAIL_PORT=587
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_ENCRYPTION=tls
MAIL_FROM_ADDRESS="hello@example.com"
MAIL_FROM_NAME="${APP_NAME}"

AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=us-east-1
AWS_BUCKET=
AWS_USE_PATH_STYLE_ENDPOINT=false

VITE_APP_NAME="${APP_NAME}"

REVERB_APP_ID=eloquente-local
REVERB_APP_KEY=eloquente-reverb-key
REVERB_APP_SECRET=eloquente-reverb-secret
REVERB_HOST=localhost
REVERB_PORT=8085
REVERB_SCHEME=http

VITE_REVERB_APP_KEY="${REVERB_APP_KEY}"
VITE_REVERB_HOST="${REVERB_HOST}"
VITE_REVERB_PORT="${REVERB_PORT}"
VITE_REVERB_SCHEME="${REVERB_SCHEME}"

BROADCAST_CONNECTION=reverb

PAYMONGO_BASE_URL=https://api.paymongo.com
PAYMONGO_CHECKOUT_ENDPOINT=/v1/checkout_sessions
PAYMONGO_PUBLIC_KEY=your_paymongo_public_key
PAYMONGO_SECRET_KEY=your_paymongo_secret_key
PAYMONGO_LIVE_PUBLIC_KEY=your_paymongo_live_public_key
PAYMONGO_LIVE_SECRET_KEY=your_paymongo_live_secret_key
PAYMONGO_WEBHOOK_SECRET=
PAYMONGO_CURRENCY=PHP
PAYMONGO_PAYMENT_METHOD_TYPES=card,gcash,paymaya
PAYMONGO_SEND_EMAIL_RECEIPT=true
PAYMONGO_STATEMENT_DESCRIPTOR=ELOQUENTE
PAYMONGO_TIMEOUT=20
PAYMONGO_CA_BUNDLE=storage/app/cacert.pem
PAYMONGO_WEBHOOK_TOLERANCE=300

# Find your ngrok path by running: where.exe ngrok
# Use SINGLE QUOTES around the path to avoid escape errors
NGROK_PATH=''
